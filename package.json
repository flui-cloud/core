{
  "name": "@flui-cloud/core",
  "version": "0.0.1",
  "description": "Open-source platform to deploy applications across cloud providers and your own servers, via the open flui.yaml manifest.",
  "author": "Dawit Abate <hello@flui.cloud>",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.32.1",
  "homepage": "https://flui.cloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/flui-cloud/core.git"
  },
  "bugs": {
    "url": "https://github.com/flui-cloud/core/issues"
  },
  "keywords": [
    "flui",
    "flui-yaml",
    "paas",
    "self-hosted",
    "open-source",
    "multi-cloud",
    "hetzner",
    "scaleway",
    "contabo",
    "application-deployment",
    "agpl"
  ],
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug 9229 --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "openapi-generator": "openapi-generator-cli",
    "generate:contabo-client": "npm run openapi-generator -- generate -i ./src/modules/providers/implementations/contabo/openapi.json -g typescript-axios -o ./src/modules/providers/implementations/contabo/generated --additional-properties=npmName=contabo-api,supportsES6=true,withInterfaces=true",
    "generate:hetzner-client": "npm run openapi-generator -- generate -i ./src/modules/providers/implementations/hetzner/openapi.json -g typescript-axios -o ./src/modules/providers/implementations/hetzner/generated --additional-properties=npmName=hetzner-api,supportsES6=true,withInterfaces=true",
    "generate:scaleway-client": "node ./scripts/generate-scaleway-clients.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d src/config/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/data-source.ts",
    "cli": "ts-node -r tsconfig-paths/register ./cli/bin/run",
    "cli:build": "cd cli && pnpm run build",
    "catalog:validate": "ts-node -r tsconfig-paths/register ./scripts/catalog-validate.ts",
    "catalog:smoke-test": "ts-node -r tsconfig-paths/register ./scripts/catalog-smoke-test.ts",
    "catalog:diagnose": "ts-node -r tsconfig-paths/register ./scripts/catalog-diagnose.ts",
    "docker:build-agents": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh node",
    "docker:build-agents:all": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh all",
    "docker:build-agents:node": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh node",
    "docker:build-agents:java": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh java",
    "docker:build-agents:plugins": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh plugins",
    "docker:build-agents:all-with-plugins": "bash src/modules/build-agents/templates/dockerfiles/build-and-push.sh all-with-plugins",
    "docker:build-agents:help": "echo 'Build asdf-based agent images. Requirements: Docker buildx, GITHUB_TOKEN env var, GITHUB_USERNAME env var. Usage: npm run docker:build-agents[:node|:java|:all|:plugins|:all-with-plugins]'",
    "dev:tunnel": "ngrok http 3000",
    "dev:info": "node internal-docs/scripts/show-ngrok-url.js",
    "knip": "knip",
    "knip:production": "knip --production",
    "sonar:up": "docker compose -f docker-compose.sonar.yml up -d && echo 'SonarQube starting at http://localhost:9000 (admin/admin first login).'",
    "sonar:down": "docker compose -f docker-compose.sonar.yml down",
    "sonar:reset": "docker compose -f docker-compose.sonar.yml down -v",
    "sonar:logs": "docker compose -f docker-compose.sonar.yml logs -f sonarqube",
    "sonar:scan": "dotenv -e .env.local -- bash -c 'docker run --rm -e SONAR_HOST_URL=http://host.docker.internal:9000 -e SONAR_TOKEN=$SONAR_TOKEN -v \"$PWD:/usr/src\" sonarsource/sonar-scanner-cli'",
    "sonar:report": "dotenv -e .env.local -- ts-node -r tsconfig-paths/register internal-docs/scripts/sonar-report.ts",
    "sonar:bulk-mark": "dotenv -e .env.local -- ts-node -r tsconfig-paths/register internal-docs/scripts/sonar-bulk-mark.ts",
    "sonar:loop": "pnpm run sonar:scan && pnpm run sonar:report",
    "prepare": "husky"
  },
  "lint-staged": {
    "{src,test}/**/*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@flui-cloud/spec": "^0.1.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@kubernetes/client-node": "^1.4.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^11.0.2",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.15.4",
    "@types/uuid": "^10.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.4",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.9",
    "ioredis": "^5.10.1",
    "ip-cidr": "^4.0.2",
    "ipaddr.js": "^2.3.0",
    "js-yaml": "^4.1.1",
    "jwks-rsa": "^4.0.1",
    "keyv": "^5.6.0",
    "libsodium-wrappers": "^0.8.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.1.7",
    "ssh2": "^1.16.0",
    "typeorm": "^0.3.20",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@openapitools/openapi-generator-cli": "^2.17.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "knip": "^6.12.1",
    "lint-staged": "^17.0.2",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "pnpm": {
    "overrides": {
      "whatwg-url": "^14.0.0"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "modulePaths": [
      "<rootDir>/.."
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
