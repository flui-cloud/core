# ============================================================
# LOCAL DEVELOPMENT
# ============================================================
# This file holds non-sensitive defaults checked into VCS. Secrets
# (DB_PASSWORD, REDIS_PASSWORD, JWT_SECRET, ENCRYPTION_KEY, FLUI_API_KEY,
# SSH_CA_PRIVATE_KEY, GRAFANA_ADMIN_PASSWORD) belong in .env.local, which
# is gitignored. Generate it with `flui dev creds`.
#
# DB and Redis hosts default to 127.0.0.1 because `flui dev tunnel` opens
# SSH-backed local forwards to the cluster's ClusterIP Services. Without
# the tunnel running these endpoints will be unreachable.

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=fluicloud
# DB_PASSWORD set in .env.local — run `flui dev creds`
DB_NAME=fluicloud

# Server Configuration
PORT=3000

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD set in .env.local — run `flui dev creds`

# Cache Configuration
# Enable/disable application cache (set to 'false' to disable caching)
CACHE_ENABLED=true
# Redis database number for cache (Bull uses db:0, cache uses db:1)
CACHE_REDIS_DB=1
# TTL for configuration data (node sizes, pricing, regions) in seconds - Default: 24 hours
CACHE_TTL_CONFIG=86400
# TTL for operational data (instances, servers, SSH keys) in seconds - Default: 1 hour
CACHE_TTL_OPERATIONAL=3600
# TTL for real-time data (server status, details) in seconds - Default: 30 seconds
CACHE_TTL_REALTIME=30

# Encryption — set in .env.local (run `flui dev creds`).
# Generate manually with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Git Workspace (optional - defaults to OS temp directory)
# Windows: C:\Users\{username}\AppData\Local\Temp\flui-git-workspace
# Linux/Mac: /tmp/flui-git-workspace
# GIT_WORKSPACE_ROOT=/tmp/flui-git-workspace

# Webhook Configuration
# Production: https://api.flui.cloud
# Note: localhost will NOT work - GitHub cannot reach your local machine
WEBHOOK_BASE_URL=http://localhost:3000

# Build Agent API Configuration
# URL base for build agents to communicate with the API
# Production: https://api.flui.cloud
# Note: localhost will NOT work for real cloud agents - use public IP or DNS
API_BASE_URL=http://localhost:3000

# In-cluster Build Agent Master Switch
# When false (default), no resources are allocated in the user's cluster
# flui-build namespace: no namespace, no PVC, no secrets, no build/cache-inspect pods.
# GIT_BUILD applications must then rely on the GitHub Actions workflow path
# (generate-workflow + ApplicationBuildWatcherService) for their builds.
# Set to 'true' to re-enable the legacy in-cluster buildkit+railpack path.
FLUI_IN_CLUSTER_BUILD_AGENT_ENABLED=false

# Provider Credentials (optional, for specific providers)
# HETZNER_API_TOKEN=
# CONTABO_CLIENT_ID=
# CONTABO_CLIENT_SECRET=
# CONTABO_API_USER=
# CONTABO_API_PASSWORD=

# ============================================================
# GITHUB APP CONFIGURATION (Managed Flui — recommended)
# ============================================================
# Create a GitHub App at https://github.com/settings/apps/new
# Required permissions: contents (write), actions (read+write), workflows (write), packages (write)
# Subscribe to webhook events: installation, workflow_run, push
# Set webhook URL to: <your-api-url>/api/v1/webhooks/github-app
#
# GITHUB_APP_ID=123456
# Private key: use EITHER inline value OR path to .pem file (not both)
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/github-app.pem  # store the key outside the repo, e.g. ~/.flui/keys/
# GITHUB_APP_WEBHOOK_SECRET=whsec_your_secret_here
# GITHUB_APP_SLUG=flui-cloud
# User-to-Server OAuth (required for pulling private packages from the user's
# GHCR namespace when the App is owned by a different org). On the App page
# enable "Request user authorization (OAuth) during installation", then paste
# the client id (from "About", same as GITHUB_APP_ID in most cases) and the
# client secret (generate one under "Client secrets").
# GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
# GITHUB_APP_CLIENT_SECRET=
# Dashboard base URL — used by the API to build redirect URLs (e.g. after
# the GitHub App callback). Override in prod to your dashboard origin.
# DASHBOARD_URL=http://localhost:4200
# Full post-install redirect. Takes precedence over DASHBOARD_URL if set.
# GITHUB_APP_POST_INSTALL_REDIRECT=http://localhost:4200/github/installed
# Interval (ms) for refreshing GHCR pull secrets in K8s namespaces.
# GitHub App installation tokens expire after 1h; default is 45 min.
# GHCR_SECRET_REFRESH_INTERVAL_MS=2700000

# ============================================================
# GITHUB OAUTH APP CONFIGURATION (Alternative to GitHub App)
# ============================================================
# Create an OAuth App at https://github.com/settings/developers
# Set callback URL to: <your-api-url>/api/v1/repositories/github/callback
#
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=

# GitHub Container Registry (for building and pushing agent Docker images)
# Required for: npm run docker:build-agents
# Generate a Classic Personal Access Token with 'write:packages' scope at:
# https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_USERNAME=your-github-username

# Docker Build Configuration (optional)
# Platform targets for multi-architecture builds
# Default: linux/amd64,linux/arm64 (multi-arch)
# For faster builds or to avoid QEMU issues on Windows: linux/amd64
# PLATFORM=linux/amd64

# Docker Build Cache Configuration (optional)
# Cache mode controls how Docker layer cache is stored/retrieved
# Options:
#   registry - Store cache in GHCR (default, best for CI/CD, requires network)
#   local    - Store cache locally at /tmp/buildkit-cache (faster for repeated local builds)
#   none     - No caching (slowest, always rebuild from scratch)
# CACHE_MODE=registry
#
# Cache registry location (only used when CACHE_MODE=registry)
# Default: ghcr.io/flui-cloud/cache
# CACHE_REGISTRY=ghcr.io/flui-cloud/cache

# Deployment Mode
# - local: Development with localhost PostgreSQL/Redis
# - cluster: Production with observability cluster services (K3s)
DEPLOYMENT_MODE=local

# Startup Health Checks
# Skip startup health checks (not recommended for production)
# Set to 'true' to disable pre-flight checks on API startup
SKIP_STARTUP_CHECKS=false

# Observability Configuration
# Mode: "docker" (local development) or "k3s" (production)
OBSERVABILITY_MODE=docker

# Prometheus endpoint for metrics scraping and queries
# K3s in-cluster: http://prometheus.flui-observability:9090
# Dev local: http://localhost:9090
PROMETHEUS_ENDPOINT=http://localhost:9090

# Loki endpoint for log aggregation
# K3s in-cluster: http://loki.flui-observability:3100
# Dev local: http://localhost:3100
LOKI_ENDPOINT=http://localhost:3100

# Grafana endpoint
# K3s in-cluster: http://grafana.flui-observability:3000
# Dev local: http://localhost:3000
GRAFANA_URL=http://localhost:3000
# GRAFANA_ADMIN_PASSWORD set in .env.local — run `flui dev creds`
GRAFANA_ADMIN_USERNAME=admin

# ============================================================
# PROMETHEUS HTTP SERVICE DISCOVERY CONFIGURATION
# ============================================================

# Flui API Endpoint for Prometheus HTTP Service Discovery
# This URL must be reachable from the observability cluster for Prometheus to discover targets
#
# Usage: Prometheus in the observability cluster polls this endpoint every 30 seconds
#        to dynamically discover all managed infrastructure (VPS, K3s nodes, build agents)
#
# Examples:
#   Development (localhost):     http://localhost:3000
#   Production (public IP):      http://93.184.216.34:3000
#   Production (DNS):            https://api.flui.cloud
#
# Important Notes:
# - For LOCAL development: Use http://localhost:3000 (Prometheus must run on same machine)
# - For REMOTE observability cluster: Use public IP or DNS (must be internet-accessible)
# - The endpoint /api/v1/observability/prometheus/targets will be appended automatically
# - DO NOT include trailing slash
# - Ensure this endpoint is reachable from observability cluster master node
#
FLUI_API_ENDPOINT=http://localhost:3000

# Alternative: PUBLIC_API_URL (fallback if FLUI_API_ENDPOINT not set)
# PUBLIC_API_URL=https://api.example.com

# ============================================================
# Internal Apps — Session Cookie for ForwardAuth
# ============================================================
# The Traefik ForwardAuth Middleware placed in front of `exposure=internal`
# apps (e.g. pgweb) calls <public-api>/api/v1/authz/internal-app on each
# request. The backend's public URL is NOT set here — it is picked up from
# PUBLIC_API_URL / FLUI_API_ENDPOINT / API_BASE_URL (already populated
# dynamically by `ApiDomainSyncService` when the user configures DNS for
# the backend-hosting cluster). The cookie vars below control how the
# dashboard session is shipped to the `<slug>.internal.<zone>` sub-domain.
#
# FLUI_COOKIE_DOMAIN (recommended in production):
#   Domain attribute for the `flui_session` cookie issued at login/refresh.
#   Must be a parent of BOTH the dashboard host and the `*.internal.<zone>`
#   hosts so the browser ships the cookie cross-sub-domain (otherwise the
#   ForwardAuth Middleware always sees no session and returns 401).
#   Example: .flui.cloud   (works for app.flui.cloud + *.internal.flui.cloud)
#   Leave empty for dev against localhost (cookie host-scoped).
FLUI_COOKIE_DOMAIN=
#
# FLUI_COOKIE_SECURE (optional, default: auto — true when NODE_ENV=production):
#   Force `Secure` flag on the session cookie on/off. Useful in dev behind a
#   local HTTPS proxy or when testing over http://localhost. 'true' / 'false'.
# FLUI_COOKIE_SECURE=true
#
# FLUI_COOKIE_SAMESITE (optional, default: lax; accepts lax | strict | none):
# FLUI_COOKIE_SAMESITE=lax

# ============================================================
# Authentication Mode
# ============================================================
# AUTH_MODE controls which authentication backend is active.
#   oidc  — OpenID Connect (recommended for production, requires OIDC vars below)
#   local — Local username/password (development only, single-user)
AUTH_MODE=oidc

# Local auth secrets (required when AUTH_MODE=local, set in .env.local)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# JWT_SECRET=

# Bootstrap owner ID — the userId seeded into provider configurations during
# cluster bootstrap. Set to the OIDC subject (sub) of the admin user so that
# the bootstrapped provider config is visible to the logged-in admin.
# FLUI_BOOTSTRAP_OWNER_ID=

# ============================================================
# OIDC — Identity Provider (OpenID Connect / JWT Auth)
# ============================================================
# These env vars are provider-agnostic. The bundled identity provider is
# currently Zitadel, but the names are generic so the platform can swap
# providers (Keycloak, Auth0, etc.) without touching env wiring.
#
# OIDC_ISSUER: the base URL of the identity provider (no trailing slash)
#   Example (K8s bootstrap): https://auth.<master-ip>.nip.io
#   Example (custom domain):  https://auth.flui.cloud
#
# OIDC_AUDIENCE: the Resource ID / client ID of the Flui API application
#   registered in the provider console.
#   For Zitadel: Console → Projects → Flui → Applications → Flui API → Resource ID
#   Leave empty until the provider is running and the API app has been registered.
#
# OIDC_JWKS_URI (optional): override for the JWKS endpoint.
#   In-cluster default: http://zitadel.flui-system.svc.cluster.local:8080/oauth/v2/keys
#   (avoids self-signed/staging TLS issues during token validation).
#   Derived from OIDC_ISSUER if not set.
#
OIDC_ISSUER=https://<auth-domain>
OIDC_AUDIENCE=<resource-id-from-provider-console>
OIDC_JWKS_URI=
#
# ZITADEL_SERVICE_ACCOUNT_PAT: Zitadel-specific admin API token.
#   Required only for the sync-auth-domain endpoint (domain migration via
#   Zitadel admin API). Not a standard OIDC concept — kept ZITADEL_-prefixed
#   to make its scope explicit.
#   Create it in: Zitadel Console → Users → flui-admin → Personal Access Tokens
ZITADEL_SERVICE_ACCOUNT_PAT=

# ============================================================
# Deploy & Catalog timeouts
# ============================================================
# Tuning knobs for how long Flui waits on Kubernetes readiness during an
# application deploy or a catalog app install. All values are milliseconds.
# The defaults are tuned for shared clusters with local-path storage; bump
# them on slower storage backends (EBS, Ceph, NFS), on clusters that pull
# large images, or when the scheduler backs off due to pressure.
#
# FLUI_DEPLOY_READINESS_TIMEOUT_MS
#   Max time the deploy processor waits for a Deployment/StatefulSet/
#   DaemonSet to reach readiness when the app has no persistent volumes.
#   Default: 300000 (5 minutes).
FLUI_DEPLOY_READINESS_TIMEOUT_MS=300000
#
# FLUI_DEPLOY_READINESS_TIMEOUT_WITH_VOLUMES_MS
#   Same as above but applied when the app declares at least one volume.
#   Higher because PVC provisioning (WaitForFirstConsumer on local-path,
#   CSI driver attach on cloud storage) adds time before the pod can start.
#   Default: 600000 (10 minutes).
FLUI_DEPLOY_READINESS_TIMEOUT_WITH_VOLUMES_MS=600000
#
# FLUI_CATALOG_INSTALL_WAIT_TIMEOUT_MS
#   Max time the catalog install processor waits for the underlying deploy
#   operation to reach COMPLETED. Should always be >= the deploy timeouts
#   above, with some headroom for queue latency.
#   Default: 900000 (15 minutes).
FLUI_CATALOG_INSTALL_WAIT_TIMEOUT_MS=900000
#
# FLUI_CATALOG_INSTALL_POLL_INTERVAL_MS
#   How often the catalog install processor polls the deploy operation
#   status. Lower = more responsive, higher = less DB load.
#   Default: 3000 (3 seconds).
FLUI_CATALOG_INSTALL_POLL_INTERVAL_MS=3000

# ============================================================
# Backup — Object Storage pricing (cost estimation)
# ============================================================
# Public provider list prices. Update when a provider changes their pricing.
# Sources: https://www.hetzner.com/storage/object-storage/
#          https://www.scaleway.com/en/pricing/storage/
# Last verified: 2026-05
#
# Hetzner Object Storage: fixed monthly fee (€4.99/mo), not per-GB — pricing
# disabled for now (UI will show N/A).
#
# Scaleway Object Storage Standard (Multi-AZ): €0.0146/GB/mo, 75 GB free tier.
FLUI_BACKUP_PRICE_SCALEWAY_OS_BASE_CENTS_PER_MONTH=0
FLUI_BACKUP_PRICE_SCALEWAY_OS_INCLUDED_GB=75
FLUI_BACKUP_PRICE_SCALEWAY_OS_MARGINAL_CENTS_PER_GB=1.46
